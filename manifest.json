  "shortcuts": [
    {
      "name": "Resize Image",
      "short_name": "Resize",
      "description": "Quickly resize your image",
      "url": "/?tool=resize-pixels",
      "icons": [
        {
          "src": "icons/resize-icon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Remove Background",
      "short_name": "Remove BG",
      "description": "Remove background from image",
      "url": "/?tool=remove-bg",
      "icons": [
        {
          "src": "icons/bg-remove-icon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Passport Photo",
      "short_name": "Passport",
      "description": "Create passport size photos",
      "url": "/?tool=passport-size",
      "icons": [
        {
          "src": "icons/passport-icon-96x96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "image",
          "accept": ["image/*"]
        }
      ]
    }
  },
  
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "image/png": [".png"],
        "image/jpeg": [".jpg", ".jpeg"],
        "image/webp": [".webp"],
        "image/gif": [".gif"]
      }
    }
  ],
  
  "prefer_related_applications": false
}
